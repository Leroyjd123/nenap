# ============================================================================
# Nenap — environment template. Copy to .env and fill in.
# NOTE: Supabase setup is DEFERRED — placeholders are fine until then.
#       Local dev can run against the docker-compose Postgres below.
# ============================================================================

# ---- Database (Prisma) ----
# Local docker-compose Postgres (default). Replace with the Supabase pooled
# connection string when Supabase is set up.
DATABASE_URL="postgresql://nenap:nenap@localhost:5432/nenap?schema=public"

# ---- Supabase (DEFERRED — placeholders until project is created) ----
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="placeholder-anon-key"
SUPABASE_SERVICE_ROLE_KEY="placeholder-service-role-key"
# Settings → API → JWT Settings → JWT Secret. NestJS verifies tokens with this.
SUPABASE_JWT_SECRET="placeholder-super-secret-jwt-token-with-at-least-32-characters"

# ---- Gemini (used from Phase 4) ----
GEMINI_API_KEY="placeholder-gemini-key"

# ---- Backend ----
BACKEND_PORT="4000"
# Comma-separated allowed origins for CORS
CORS_ORIGINS="http://localhost:3000"

# ---- Frontend (Next.js) — only NEXT_PUBLIC_* reach the browser ----
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="placeholder-anon-key"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
