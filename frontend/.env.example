# Frontend env — copy to frontend/.env.local. Only NEXT_PUBLIC_* reach the browser.
# Placeholders are fine until Supabase is set up (auth will be inert until then).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="placeholder-anon-key"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Dev-only demo login. Leave these UNSET in production — the button and credentials
# are then absent from the build entirely.
NEXT_PUBLIC_ENABLE_DEMO="true"
NEXT_PUBLIC_DEMO_EMAIL="demo@example.com"
NEXT_PUBLIC_DEMO_PASSWORD="change-me"
