# Frontend env — copy to frontend/.env.local. Only NEXT_PUBLIC_* reach the browser.
# Placeholders are fine until Supabase is set up (auth will be inert until then).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="placeholder-anon-key"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Dev-only demo login. Leave these UNSET in production — the button and credentials
# are then absent from the build entirely.
NEXT_PUBLIC_ENABLE_DEMO="true"
NEXT_PUBLIC_DEMO_EMAIL="demo@example.com"
NEXT_PUBLIC_DEMO_PASSWORD="change-me"

# PostHog product analytics (optional). Leave the key UNSET to disable analytics
# entirely — every tracking call becomes a no-op. Project API key from
# PostHog → Settings → Project. Host: https://us.i.posthog.com or https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Sentry error tracking (optional). Leave the DSN UNSET to disable — the SDK never
# initialises. DSN from Sentry → Project Settings → Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
# Source-map upload at build time (CI/prod only). Without these, builds skip upload.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
