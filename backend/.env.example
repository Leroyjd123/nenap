# Backend env — copy to backend/.env. Placeholders are fine until Supabase is set up.
# Pooled (pgbouncer, 6543) for runtime; DIRECT_URL (session, 5432) for migrations.
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-REGION.pooler.supabase.com:5432/postgres"
BACKEND_PORT="4000"
CORS_ORIGINS="http://localhost:3000"

# Supabase (DEFERRED). NestJS verifies JWTs with SUPABASE_JWT_SECRET.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="placeholder-service-role-key"
SUPABASE_JWT_SECRET="placeholder-super-secret-jwt-token-with-at-least-32-characters"

# Gemini (Phase 4)
GEMINI_API_KEY="placeholder-gemini-key"
