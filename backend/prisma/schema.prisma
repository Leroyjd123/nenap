// Nenap data model — full schema, designed once (Phase 1).
// Access is backend-only via this Prisma client; ownership is enforced in the service layer.
// `User.id` mirrors the Supabase auth user id (UUID from the JWT `sub`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NoteStatus {
  draft
  processing
  completed
  failed
}

enum JobStatus {
  queued
  processing
  completed
  failed
}

enum JobType {
  transcribe
  enhance
}

enum TranscriptSource {
  gemini
  web_speech
  upload
}

model User {
  id          String   @id @db.Uuid // = Supabase auth user id
  email       String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folders Folder[]
  notes   Note[]
  tags    Tag[]

  @@map("users")
}

model Folder {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String   @db.VarChar(60)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes Note[]

  @@unique([userId, name])
  @@index([userId])
  @@map("folders")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String   @db.VarChar(40)
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes Note[] @relation("NoteTags")

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model Note {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @db.Uuid
  folderId        String?    @db.Uuid
  title           String     @default("") @db.VarChar(200)
  // The user's own words — NEVER overwritten by AI.
  originalContent String     @default("") @db.Text
  status          NoteStatus @default(draft)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder           Folder?              @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags             Tag[]                @relation("NoteTags")
  recording        Recording?
  transcript       Transcript?
  enhancedVersions EnhancedNoteVersion[]
  jobs             ProcessingJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, folderId])
  @@index([userId, status])
  @@map("notes")
}

model Recording {
  id          String   @id @default(uuid()) @db.Uuid
  noteId      String   @unique @db.Uuid
  userId      String   @db.Uuid
  storagePath String
  mimeType    String   @default("audio/webm")
  durationSec Int?
  sizeBytes   Int?
  createdAt   DateTime @default(now())

  note Note            @relation(fields: [noteId], references: [id], onDelete: Cascade)
  jobs ProcessingJob[]

  @@index([userId])
  @@map("recordings")
}

model ProcessingJob {
  id          String    @id @default(uuid()) @db.Uuid
  noteId      String    @db.Uuid
  recordingId String?   @db.Uuid
  type        JobType
  status      JobStatus @default(queued)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error       String?   @db.Text
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  note      Note       @relation(fields: [noteId], references: [id], onDelete: Cascade)
  recording Recording? @relation(fields: [recordingId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt]) // drives the stuck-job sweep
  @@index([noteId])
  @@map("processing_jobs")
}

model Transcript {
  id        String           @id @default(uuid()) @db.Uuid
  noteId    String           @unique @db.Uuid
  content   String           @db.Text
  source    TranscriptSource @default(gemini)
  createdAt DateTime         @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@map("transcripts")
}

model EnhancedNoteVersion {
  id        String   @id @default(uuid()) @db.Uuid
  noteId    String   @db.Uuid
  version   Int
  content   String   @db.Text
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, version])
  @@index([noteId])
  @@map("enhanced_note_versions")
}
